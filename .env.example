# ============================================================================
# Etiquetador Morfosintactico HMM - Variables de Entorno
# ============================================================================
# Copia este archivo a .env y configura los valores

# -- Entorno --
# Valores: development, production
ENV=development

# -- Supabase (opcional - el sistema funciona sin conexion) --
SUPABASE_URL=https://supabase-maestria.iagentek.com.mx
SUPABASE_KEY=

# -- Rutas (solo necesario en Docker, los defaults locales funcionan) --
# CORPUS_DIR=/app/corpus
# EXPORTS_DIR=/app/exports
# CACHE_DIR=/app/cache

# ============================================================================
# NXT AI Development Framework (opcional)
# ============================================================================

# Google Gemini API Key (para busquedas y multimedia)
# Obtener en: https://aistudio.google.com/apikey
# GEMINI_API_KEY=AIza...

# GitHub Token (para MCP server)
# GITHUB_TOKEN=ghp_...
